# ============================================================
# IPL AUCTION HOUSE — ENVIRONMENT VARIABLES
# Copy this to .env.local and fill in the values
# NEVER commit .env.local to git
# ============================================================

# --- Next.js ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- JWT (generate with: openssl rand -hex 48) ---
JWT_SECRET=your-super-long-random-secret-minimum-48-chars

# --- Socket.IO (Railway URL in production) ---
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# --- LiveKit (voice chat) ---
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# --- Admin (hashed with bcrypt cost 12) ---
ADMIN_USERNAME=ipl_admin
ADMIN_PASSWORD_HASH=$2a$12$your-bcrypt-hash-here

# --- App Settings ---
NEXT_PUBLIC_BUDGET_CR=120
NEXT_PUBLIC_MAX_SQUAD=25
NEXT_PUBLIC_MAX_OVERSEAS=4
